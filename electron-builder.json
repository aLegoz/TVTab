{
  "appId": "com.tvtab.app",
  "productName": "TVTab",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "out/**/*",
    "!**/.{eslintignore,htmlhintrc,stylelintrc,gitignore,npmignore,editorconfig}",
    "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,__pycache__,thumbs.db,.gitignore}",
    "!**/{.flowconfig,.idea,.vs,idea}",
    "!**/{karma.conf.js,.eslintrc.js}"
  ],
  "extraResources": [
    {
      "from": "node_modules/sql.js/dist/sql-wasm.wasm",
      "to": "sql-wasm.wasm"
    }
  ],
  "win": {
    "target": [{ "target": "portable", "arch": ["x64"] }]
  }
}
